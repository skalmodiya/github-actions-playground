# GitHub Actions Playground

# Copy this to .env and fill in values
GITHUB_REPO=skalmodiya/github-actions-playground

# For self-hosted runner (optional — use runner profile)
# Get token from: GitHub repo → Settings → Actions → Runners → New self-hosted runner
RUNNER_REPO_URL=https://github.com/skalmodiya/github-actions-playground
RUNNER_TOKEN=
